# ── App ──────────────────────────────────────────────────
APP_NAME="Student Utility API"
APP_VERSION="1.0.0"
DEBUG=True

# ── Database ─────────────────────────────────────────────
# When running via Docker: host = "db" (service name in docker-compose)
# When running locally:    host = "localhost"
DATABASE_URL=postgresql://postgres:postgres@db:5432/student_db

# ── PostgreSQL Connection Pool ───────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True

# ── Auth ─────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string before deploying!
SECRET_KEY=kVgB6xhheEIdyKK_2eT1RNsJqxJN009jKNFQVPbziE6gOi7tI_n2OV6ZYveY2fRb6-r3DspRRw-FBdUBieuREg
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Redis ────────────────────────────────────────────────
# When running via Docker: host = "redis" (service name in docker-compose)
# When running locally:    host = "localhost"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password   # uncomment if Redis has auth

# ── CORS (Production Hardening) ──────────────────────────
# Development:  CORS_ORIGINS=["*"]
# Production:   Set to your actual frontend domain(s)
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Rate Limiting ────────────────────────────────────────
# Override these to tune rate limits per environment
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_SUBMIT_MAX=10
RATE_LIMIT_SUBMIT_WINDOW=60

# ── Email / SMTP Notifications ───────────────────────────
# Set NOTIFICATIONS_ENABLED=True and fill in SMTP credentials to
# activate real email reminders from the background worker.
NOTIFICATIONS_ENABLED=False
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password        # use an App Password, not your main password
# SMTP_FROM=noreply@student-utility.app
