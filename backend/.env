# ── App ──────────────────────────────────────────────────
APP_NAME="Student Utility API"
APP_VERSION="1.0.0"
DEBUG=True

# ── Database ─────────────────────────────────────────────
# When running via Docker: host = "db" (service name in docker-compose)
# When running locally:    host = "localhost"
DATABASE_URL=postgresql://postgres:postgres@db:5432/student_db

# ── PostgreSQL Connection Pool ───────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True

# ── Auth ─────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string before deploying!
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Redis ────────────────────────────────────────────────
# When running via Docker: host = "redis" (service name in docker-compose)
# When running locally:    host = "localhost"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password   # uncomment if Redis has auth
